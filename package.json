{
  "name": "education-analysis-app",
  "version": "1.0.0",
  "description": "Education Analysis Tool",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development tsc -p electron/tsconfig.json && electron .\"",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json && electron-builder",
    "compile": "tsc && vite build && tsc -p electron/tsconfig.json"
  },
  "build": {
    "appId": "com.education.analysis",
    "productName": "EducationAnalysis",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "Claude4_model",
        "to": "Claude4_model"
      },
      {
        "from": "Data",
        "to": "Data"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "Data Scientist Education",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "electron-squirrel-startup": "^1.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
